rmarkdown:::site_skeleton(getwd())
# Load necessary library
library(ggplot2)
# Create the data frame
data <- data.frame(
Name = c("Chicca", "Marianna", "Giorgia"),
Stupidita = c(4.8, 4.9, 5.0)  # High scores but close together
)
# Generate the plot
ggplot(data, aes(x = Name, y = Stupidita)) +
geom_bar(stat = "identity", fill = "red", alpha = 0.7) +
geom_errorbar(aes(ymin = Stupidita - 0.1, ymax = Stupidita + 0.1), width = 0.2) +
labs(title = "Levels of Stupidità", y = "Stupidità (0-5 Scale)", x = "") +
theme_minimal() +
theme(plot.title = element_text(hjust = 0.5)) +
annotate("text", x = 2, y = 5, label = "No significant difference detected!", size = 5, color = "blue")
# Generate the plot
ggplot(data, aes(x = Name, y = Stupidita)) +
geom_bar(stat = "identity", fill = "red", alpha = 0.7) +
geom_errorbar(aes(ymin = Stupidita - 0.1, ymax = Stupidita + 0.1), width = 0.2) +
labs(title = "Levels of Stupidità", y = "Stupidità (0-5 Scale)", x = "") +
theme_minimal() +
theme(plot.title = element_text(hjust = 0.5)) +
annotate("text", x = 2, y = 5, label = "There is no significant difference in stupidity between the three individuals.", size = 5, color = "blue")
# Bar plot of mean +/-se
ggbarplot(ToothGrowth, x = "dose", y = "len", add = "mean_se")+
stat_compare_means() +                                         # Global p-value
stat_compare_means(ref.group = "0.5", label = "p.signif",
label.y = c(22, 29))
library(ggpubr)
# Bar plot of mean +/-se
ggbarplot(ToothGrowth, x = "dose", y = "len", add = "mean_se")+
stat_compare_means() +                                         # Global p-value
stat_compare_means(ref.group = "0.5", label = "p.signif",
label.y = c(22, 29))                   # compare to ref.group
ToothGrowth
library(dplyr)
library(scales)
# Rename "len" to "Stupidita'"
data <- data %>%
rename(Stupidita = len)
# Original dataset
data <- ToothGrowth
# Rename "len" to "Stupidita'"
data <- data %>%
rename(Stupidita = len)
# Scale "Stupidita'" to range 0-5
data$`Stupidita` <- rescale(data$`Stupidita`, to = c(0, 5))
# Transform dose into categorical values
data$dose <- factor(data$dose, levels = c(0.5, 1.0, 2.0), labels = c("Davide", "Marianna", "Chicca"))
# Adjust values: lower for Davide, similar for Marianna and Chicca
data <- data %>%
mutate(`Stupidita` = case_when(
dose == "Davide" ~ `Stupidita` * 0.7,  # Lower Davide's values
dose == "Marianna" ~ `Stupidita` * 1.1,  # Slightly higher for Marianna
dose == "Chicca" ~ `Stupidita` * 1.05,  # Slightly higher for Chicca
TRUE ~ `Stupidita`
))
# Ensure values remain within 0-5 range
data$`Stupidita` <- pmin(pmax(data$`Stupidita`, 0), 5)
print(data)
ggbarplot(data, x = "dose", y = "Stupidita", add = "mean_se")+
stat_compare_means() +                                         # Global p-value
stat_compare_means(ref.group = "0.5", label = "p.signif",
label.y = c(22, 29))                   # compare to ref.group
# Rename "len" to "Stupidita'"
data <- data %>%
rename(Individual = dose)
ggbarplot(data, x = "Individual", y = "Stupidita", add = "mean_se")+
stat_compare_means() +                                         # Global p-value
stat_compare_means(ref.group = "0.5", label = "p.signif",
label.y = c(22, 29))                   # compare to ref.group
ggbarplot(data, x = "Individual", y = "Stupidita", add = "mean_se")+
stat_compare_means() +                                         # Global p-value
stat_compare_means(ref.group = "Davide", label = "p.signif",
label.y = c(22, 29))                   # compare to ref.group
ggbarplot(data, x = "Individual", y = "Stupidita", add = "mean_se")+
stat_compare_means() +                                         # Global p-value
stat_compare_means(ref.group = "Davide", label = "p.signif",
label.y = c(4, 5))                   # compare to ref.group
